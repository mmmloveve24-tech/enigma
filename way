<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>🪼 Jelly Focus Pro</title>
    <style>
        /* ... (копируем твои базовые стили) ... */
        :root {
            --bg-primary: #0a0a1a;
            --bg-secondary: #111128;
            --bg-card: rgba(20, 20, 50, 0.6);
            --neon-work: #b44aff;
            --neon-work-glow: rgba(180, 74, 255, 0.4);
            --neon-rest: #00ffd5;
            --neon-rest-glow: rgba(0, 255, 213, 0.4);
            --neon-accent: #ff6b9d;
            --neon-gold: #ffd700;
            --text-primary: #e8e8f0;
            --text-secondary: #8888aa;
            --neon-current: var(--neon-work);
            --neon-glow: var(--neon-work-glow);
            --transition-speed: 1s;
        }

        /* Новые стили для категорий */
        .category-selector {
            display: flex;
            gap: 5px;
            margin-bottom: 10px;
        }
        .cat-tag {
            font-size: 0.65rem;
            padding: 2px 8px;
            border-radius: 4px;
            cursor: pointer;
            border: 1px solid rgba(255,255,255,0.1);
            transition: 0.2s;
            background: rgba(255,255,255,0.05);
        }
        .cat-tag.active[data-cat="eng"] { border-color: #4a9eff; color: #4a9eff; box-shadow: 0 0 10px rgba(74,158,255,0.3); }
        .cat-tag.active[data-cat="soc"] { border-color: #ff9e4a; color: #ff9e4a; box-shadow: 0 0 10px rgba(255,158,74,0.3); }
        .cat-tag.active[data-cat="other"] { border-color: #a2a2a2; color: #eee; }

        .task-badge {
            font-size: 0.6rem;
            padding: 1px 5px;
            border-radius: 3px;
            margin-right: 8px;
            text-transform: uppercase;
        }
        .badge-eng { background: rgba(74,158,255,0.2); color: #4a9eff; }
        .badge-soc { background: rgba(255,158,74,0.2); color: #ff9e4a; }

        /* Глаза медузы в спящем режиме */
        .jellyfish.sleeping .jelly-eye {
            height: 2px;
            margin-top: 6px;
            border-radius: 1px;
        }

        /* Кнопка звука */
        .sound-toggle {
            position: absolute;
            top: 20px;
            right: 20px;
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 1.2rem;
            z-index: 10;
        }
        .sound-toggle.active { color: var(--neon-rest); text-shadow: 0 0 10px var(--neon-rest); }
        
        /* ... (вставь сюда остальные стили из своего файла) ... */
    </style>
</head>
<body>
    <div class="app-container">
        <button id="soundToggle" class="sound-toggle" onclick="toggleAmbience()" title="Глубоководный шум (M)">🌊</button>

        <section class="tasks-section">
            <div class="tasks-header">
                <h2>📋 Задачи</h2>
                <span class="task-count" id="taskCount">0 / 0</span>
            </div>
            <div class="category-selector" id="catSelector">
                <div class="cat-tag active" data-cat="other">Other (1)</div>
                <div class="cat-tag" data-cat="eng">English (2)</div>
                <div class="cat-tag" data-cat="soc">Social (3)</div>
            </div>
            <div class="task-input-area">
                <input type="text" class="task-input" id="taskInput" placeholder="Что нужно сделать?">
                <button class="btn-add" onclick="addTask()">+</button>
            </div>
            </section>
    </div>

<script>
// К существующему JS добавляем:

let currentTaskCat = 'other';
let audioCtx = null;
let noiseNode = null;
let noiseGain = null;

// Переключение категорий кликом
document.querySelectorAll('.cat-tag').forEach(tag => {
    tag.addEventListener('click', () => {
        document.querySelectorAll('.cat-tag').forEach(t => t.classList.remove('active'));
        tag.classList.add('active');
        currentTaskCat = tag.dataset.cat;
    });
});

// Синтезатор "Шума океана" (Web Audio API)
function toggleAmbience() {
    if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    }

    if (noiseNode) {
        noiseGain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.5);
        setTimeout(() => {
            noiseNode.stop();
            noiseNode = null;
            document.getElementById('soundToggle').classList.remove('active');
        }, 500);
    } else {
        const bufferSize = 2 * audioCtx.sampleRate;
        const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
        const output = noiseBuffer.getChannelData(0);
        
        // Генерация розового/коричневого шума (более мягкий)
        let lastOut = 0.0;
        for (let i = 0; i < bufferSize; i++) {
            const white = Math.random() * 2 - 1;
            output[i] = (lastOut + (0.02 * white)) / 1.02;
            lastOut = output[i];
            output[i] *= 3.5; // Усиление
        }

        noiseNode = audioCtx.createBufferSource();
        noiseNode.buffer = noiseBuffer;
        noiseNode.loop = true;

        noiseGain = audioCtx.createGain();
        noiseGain.gain.setValueAtTime(0.0001, audioCtx.currentTime);
        noiseGain.gain.exponentialRampToValueAtTime(0.15, audioCtx.currentTime + 1);

        // Фильтр низких частот для эффекта "под водой"
        const filter = audioCtx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.value = 400;

        noiseNode.connect(filter);
        filter.connect(noiseGain);
        noiseGain.connect(audioCtx.destination);

        noiseNode.start();
        document.getElementById('soundToggle').classList.add('active');
    }
}

// Модифицированная функция addTask
function addTask() {
    const input = document.getElementById('taskInput');
    const text = input.value.trim();
    if (!text) return;
    tasks.push({ 
        id: Date.now(), 
        text, 
        completed: false, 
        cat: currentTaskCat // Сохраняем категорию
    });
    input.value = '';
    renderTasks();
    saveState();
}

// Рендер с бейджами категорий
function renderTasks() {
    const list = document.getElementById('tasksList');
    // ... (старая логика подсчета) ...
    list.innerHTML = tasks.map(t => {
        const badge = t.cat === 'eng' ? '<span class="task-badge badge-eng">ENG</span>' : 
                      t.cat === 'soc' ? '<span class="task-badge badge-soc">SOC</span>' : '';
        return `
            <div class="task-item${t.completed ? ' completed' : ''}">
                <div class="task-checkbox${t.completed ? ' checked' : ''}" onclick="toggleTask(${t.id})"></div>
                <span class="task-text">${badge}${escapeHtml(t.text)}</span>
                <button class="task-delete" onclick="deleteTask(${t.id})">✕</button>
            </div>
        `;
    }).join('');
}

// Обработка состояния медузы
function updateJellyState() {
    const jelly = document.getElementById('jellyfish');
    if (isRunning) {
        jelly.classList.remove('sleeping');
    } else {
        jelly.classList.add('sleeping');
    }
}

// Новые горячие клавиши
document.addEventListener('keydown', (e) => {
    if (document.activeElement.tagName === 'INPUT') return;
    
    if (e.key === '1') document.querySelector('[data-cat="other"]').click();
    if (e.key === '2') document.querySelector('[data-cat="eng"]').click();
    if (e.key === '3') document.querySelector('[data-cat="soc"]').click();
    if (e.key.toLowerCase() === 'm') toggleAmbience();
});

// Добавь вызов updateJellyState() внутрь функции toggleTimer()
</script>
</body>
</html>
